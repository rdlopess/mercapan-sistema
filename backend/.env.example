# =============================================
# MERCAPAN BACKEND — Variaveis de ambiente
# Copie este arquivo para .env e preencha
# =============================================

# Supabase
SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=sua_service_role_key_aqui

# Servidor
PORT=3001
NODE_ENV=development

# Frontend (CORS)
FRONTEND_URL=http://localhost:5173

# =============================================
# Google Sheets (Service Account)
# Siga o guia em: supabase/docs/google-sheets.md
# =============================================
GOOGLE_SERVICE_ACCOUNT_EMAIL=mercapan@seu-projeto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_AQUI\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_ID=ID_DA_PLANILHA_AQUI

# =============================================
# Supabase Storage (bucket para PDFs)
# Crie o bucket "catalogos" no Supabase Storage
# =============================================
SUPABASE_STORAGE_BUCKET=catalogos

# URL publica do frontend (usada para gerar PDF via Playwright)
# Em producao: https://seu-frontend.vercel.app
PDF_FRONTEND_URL=http://localhost:5173
